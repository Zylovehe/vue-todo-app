# 自动检测文本文件并规范化换行符
* text=auto

# Windows 脚本使用 CRLF
*.bat text eol=crlf

# Unix 脚本使用 LF
*.sh text eol=lf

# 配置文件使用 LF
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.md text eol=lf

# 二进制文件不进行换行符转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
